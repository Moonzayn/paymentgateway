# =============================================
# PPOB EXPRESS - ENVIRONMENT CONFIGURATION
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================

# Database Configuration
DB_HOST=localhost
DB_USER=your_secure_db_user
DB_PASS=your_secure_db_password
DB_NAME=db_ppob

# Application Settings
APP_NAME="PPOB Express"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

# Security Settings
# Generate with: openssl rand -base64 32
APP_KEY=your_random_app_key_here

# Session Settings
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTP_ONLY=true

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_TIMEOUT=900

# File Upload
MAX_UPLOAD_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# Admin IP Whitelist (comma separated, leave empty to allow all)
# Example: ADMIN_IPS=192.168.1.1,10.0.0.1
ADMIN_IPS=

# Email Settings (for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_ENCRYPTION=tls

# Backup Settings
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/path/to/backups

# Logging
LOG_LEVEL=error
LOG_PATH=/path/to/logs

# API Keys (if using external APIs)
# PROVIDER_API_KEY=your_api_key_here
# PROVIDER_API_SECRET=your_api_secret_here
